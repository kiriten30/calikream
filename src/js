/**
 * CALIKREAM — Main Application Entry Point
 * Coordinates all modules and handles global initialization.
 */
(function () {
  'use strict';

  function init() {
    console.log('CALIKREAM initialized');

    // Add a slight delay then remove any initial page-load flicker
    document.body.style.opacity = '1';

    // Log ready state
    const frameCount = document.querySelectorAll('.hero__stage').length;
    console.log('Hero stages:', frameCount);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
